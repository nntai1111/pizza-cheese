# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Spring profile: dev (local) | prod (pizza-store.vn)
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (Supabase pooler example)
DATABASE_URL=jdbc:postgresql://your-host:5432/postgres
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-db-password

# JWT — generate with: openssl rand -base64 32
JWT_BASE64_SECRET=your-base64-jwt-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# VNPay Sandbox (dev) / Production (prod)
VNPAY_TMN_CODE=your-tmn-code
VNPAY_HASH_SECRET=your-hash-secret

# --- Dev overrides (optional) ---
# APP_FRONTEND_URL=http://localhost:4201
# APP_CORS_ALLOWED_ORIGINS=http://localhost:4201
# VNPAY_RETURN_URL=http://localhost:8080/api/v1/payments/vnpay/return
# VNPAY_IPN_URL=http://localhost:8080/api/v1/payments/vnpay/ipn

# --- Prod overrides (set SPRING_PROFILES_ACTIVE=prod on server) ---
# APP_FRONTEND_URL=https://pizza-store.vn
# APP_CORS_ALLOWED_ORIGINS=https://pizza-store.vn,https://www.pizza-store.vn
# VNPAY_RETURN_URL=https://api.pizza-store.vn/api/v1/payments/vnpay/return
# VNPAY_IPN_URL=https://api.pizza-store.vn/api/v1/payments/vnpay/ipn
